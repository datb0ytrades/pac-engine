# =============================================================================
# PAC Engine - Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# DGI (Dirección General de Ingresos)
DGI_ENVIRONMENT=sandbox          # sandbox | production
DGI_WS_URL=                      # DGI web service endpoint

# Firma Electrónica (local signing - Express API)
SIGNING_CERT_PATH=               # Path to PEM certificate
SIGNING_KEY_PATH=                # Path to PEM private key

# Signing Microservice (used by Edge Functions)
SIGNING_SERVICE_URL=https://your-signing-service.railway.app
SIGNING_SERVICE_SECRET=your-shared-secret

# Signing Certificate (used by signing-service on Railway)
SIGNING_P12_BASE64=              # Base64-encoded P12 certificate
SIGNING_P12_PASSWORD=            # P12 certificate password

# AI Features
ANTHROPIC_API_KEY=               # For expense categorization & receipt scanning

# Server
PORT=3000
NODE_ENV=development             # development | production | test
